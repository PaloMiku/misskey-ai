# 定时调度插件配置示例文件
# 复制此文件为 config.yaml 并根据需要修改

enabled: true                          # 是否启用插件
priority: 90                           # 插件优先级（数字越大优先级越高）

# 每日发送配置
daily_enabled: true                    # 是否启用每日发送
daily_hour: 9                          # 每日发送时间 - 小时 (0-23)
daily_minute: 0                        # 每日发送时间 - 分钟 (0-59)

# 节日发送配置  
holiday_enabled: true                  # 是否启用节日发送

# 启动和重连配置
startup_enabled: true                  # 是否启用启动时发送
reconnect_enabled: true                # 是否启用重连时发送

# 每日发送的消息列表（随机选择一条）
daily_messages:
  - "新的一天开始了！今天也要加油哦~ ✨"
  - "早上好！希望大家今天都有美好的一天 🌅"
  - "每天都是全新的开始，让我们一起努力吧！💪"
  - "今天天气不错呢，大家记得保持好心情~ ☀️"

# 节日发送的消息（key: 日期，value: 消息内容或消息列表）
holiday_messages:
  # 阳历节日 - 使用 MM-DD 格式
  "01-01":
    - "新年快乐！🎉 祝大家新的一年里身体健康，工作顺利！"
    - "元旦快乐！新的一年，新的开始！"
  "02-14":
    - "情人节快乐！💕 愿有情人终成眷属~"
  "12-25":
    - "圣诞节快乐！🎄 Merry Christmas!"
  
  # 也可以使用中文格式
  "春节": "春节快乐！🧧 恭喜发财，万事如意！"
  "中秋节": "中秋节快乐！🥮 花好月圆，团团圆圆！"

# 机器人启动时发送的消息
startup_messages:
  - "我回来了！✨ 系统重新启动完成~"
  - "启动完成！🚀 大家好，我又上线啦！"
  - "系统初始化完毕！💻 准备就绪~"

# 断线重连后发送的消息
reconnect_messages:
  - "网络连接恢复！📶 现在一切正常了~"
  - "重连成功！🔗 抱歉刚才的断线"
